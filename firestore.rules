rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /profile/{profileID} {
        allow read, create, update, delete: if isOwner(uid) && profileID == "main";
      }

      match /journalEntries/{entryID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /aiReflectionSessions/{sessionID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /quests/{questID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /tipsPracticeSessions/{sessionID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /rewardState/{rewardStateID} {
        allow read, create, update, delete: if isOwner(uid) && rewardStateID == "main";
      }

      match /pointEntries/{pointEntryID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /activityEvents/{activityEventID} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /circles/{circleID} {
      allow read, create, update, delete: if false;

      match /{circleDocument=**} {
        allow read, create, update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, create, update, delete: if false;
    }
  }
}
